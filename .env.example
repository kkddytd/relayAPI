# Web/API service.
# The page is reachable from the server/LAN by default. Detection requests
# still require DETECTOR_API_KEYS when the deploy script has generated one.
HOST=0.0.0.0
PORT=6722

# Optional production protection. Leave unset for local testing mode.
VITE_TURNSTILE_SITE_KEY=
VITE_INSTALL_REPORT_BASE_URL=
TURNSTILE_SECRET_KEY=
TURNSTILE_ALLOWED_HOSTNAMES=localhost,127.0.0.1
TURNSTILE_RATE_LIMIT_MAX=20
TURNSTILE_MAX_CONCURRENCY=4

# Public detection API authentication. Deploy scripts generate this in .env
# when it is empty. Keep the generated value private.
DETECTOR_API_KEYS=
DETECTION_MAX_CONCURRENCY=2
DETECTION_SEED_SECRET=

# Local persistence. Request credentials and full request details are encrypted
# with AES-256-GCM before SQLite storage.
DATA_DIR=./data
SQLITE_PATH=
WEB_SESSION_SECRET=
ATTACHMENT_ORPHAN_RETENTION_HOURS=24
# Optional comma-separated visual models tried only when the selected model
# does not receive a native image or PDF. Reports expose the actual model used.
ATTACHMENT_FALLBACK_MODELS=
ATTACHMENT_FALLBACK_PROTOCOLS=
ATTACHMENT_FALLBACK_ATTEMPTS=3

# Separate installation-report service. POST /api/v1/installations/report has
# no request body and records one report event per call.
INSTALL_TRACKER_URL=http://127.0.0.1:6723
INSTALL_TRACKER_HOST=127.0.0.1
INSTALL_TRACKER_PORT=6723
INSTALL_TRACKER_DATA_DIR=./data/install-tracker
INSTALL_TRACKER_TIME_ZONE=Asia/Shanghai
# Trust forwarding headers only when the tracker is reached through a
# loopback reverse proxy that overwrites them (for example local Nginx).
INSTALL_TRACKER_TRUST_PROXY=false

# Optional hardening for deployments exposed beyond localhost.
# This limits JSON metadata requests, not streamed multipart attachments.
MAX_REQUEST_BODY_BYTES=2097152
INBOUND_REQUEST_TIMEOUT_MS=30000
SERVER_MAX_CONNECTIONS=256
UPSTREAM_TIMEOUT_MS=120000
MAX_UPSTREAM_RESPONSE_BYTES=16777216
LIVE_KNOWLEDGE_TTL_MS=900000
LIVE_KNOWLEDGE_MAX_RESPONSE_BYTES=2097152
LIVE_KNOWLEDGE_TIME_ZONE=Asia/Shanghai
PROBE_MAX_CONCURRENCY=8
PROBE_RATE_LIMIT_WINDOW_MS=60000
PROBE_RATE_LIMIT_MAX=60
LOG_RETENTION_DAYS=7
MAX_LOG_ENTRY_BYTES=262144
MAX_LOG_FILE_BYTES=52428800

# Only trust forwarding headers when the reverse proxy path is controlled.
TRUST_PROXY=false
TRUSTED_PROXY_ADDRESSES=

# The browser page uses this same-origin relay. The documented detector API
# remains independently protected by DETECTOR_API_KEYS.
ALLOW_PUBLIC_PROBE_WITHOUT_TURNSTILE=true

# Explicitly trust direct RFC1918/ULA browser clients for probe, attachment, and
# history routes. Enable only on a controlled LAN; arbitrary uploads are allowed.
ALLOW_LAN_WEB_WITHOUT_TURNSTILE=false

# The static page and its anonymous Web session are public by default. This is
# separate from DETECTOR_API_KEYS: POST /api/v1/detections still requires Bearer auth.
ALLOW_PUBLIC_WEB_WITHOUT_TURNSTILE=true

# Token sent by the bundled loopback Nginx reverse proxy. It is only accepted
# from a loopback peer; change both this value and the proxy header if needed.
TRUSTED_WEB_PROXY_TOKEN=kk-public-web-via-loopback

# Only enable this when private/internal upstreams are intentionally required.
ALLOW_PRIVATE_UPSTREAMS=false
